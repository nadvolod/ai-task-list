{
  "name": "ai-task-list",
  "version": "0.1.0",
  "description": "AI-powered task capture and prioritization with image upload, voice commands, and intelligent scoring",
  "license": "MIT",
  "author": "Nikolay Advolodkin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nadvolod/ai-task-list.git"
  },
  "bugs": {
    "url": "https://github.com/nadvolod/ai-task-list/issues"
  },
  "homepage": "https://github.com/nadvolod/ai-task-list#readme",
  "keywords": [
    "nextjs",
    "ai",
    "task-management",
    "openai",
    "gemini",
    "voice-commands",
    "neon-postgres"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "npx tsx src/scripts/migrate.ts",
    "db:seed": "npx tsx src/scripts/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.0.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "openai": "^6.27.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
